{
  "hooks": {
    "agentSpawn": [
      {
        "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && gt prime --hook && gt mail check --inject"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && gt mail check --inject"
      }
    ],
    "stop": [
      {
        "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && gt signal kiro-stop"
      }
    ]
  }
}
